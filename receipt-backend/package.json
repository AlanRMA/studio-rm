{
  "name": "receipt-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:all": "tsx src/scripts/migrate.ts all",
    "migrate:dev": "APP_ENV=development tsx src/scripts/migrate.ts development",
    "migrate:prod": "APP_ENV=production tsx src/scripts/migrate.ts production",
    "setup:supabase": "npm run migrate:all && APP_ENV=development npm run clean:all",
    "test:crud": "tsx src/scripts/manual-crud-test.ts",
    "clean:all": "tsx src/scripts/clean-all.ts",
    "clean:dev": "APP_ENV=development tsx src/scripts/clean-all.ts",
    "clean:prod": "APP_ENV=production tsx src/scripts/clean-all.ts",
    "seed:dummy": "tsx src/scripts/seed-dummy.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "pg": "^8.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}